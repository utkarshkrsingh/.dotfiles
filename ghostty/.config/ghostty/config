# Font
font-family = "ProFont IIx Nerd Font"
font-size = 14

# Transparency
background-opacity = 1.0
background-blur-radius = 20

# Cursor
cursor-style = bar

# Window size
window-width = 170
window-height = 50

# Window Padding
window-padding-x = 15
window-padding-y = 15

# Theme
theme = TokyoNight Night

# Mouse
mouse-hide-while-typing = true
