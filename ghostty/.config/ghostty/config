# Font
font-family = "JetBrainsMono Nerd Font"
# font-family = "ProFont IIx Nerd Font"
font-size = 15

# Transparency
background-opacity = 1.0
background-blur-radius = 20

# Cursor
cursor-style = bar

# Window size
window-width = 150
window-height = 40

# Window Padding
window-padding-x = 15
window-padding-y = 15

# Theme
theme = tokyonight_night

# Mouse
mouse-hide-while-typing = true
